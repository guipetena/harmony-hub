# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/harmonyhub"

# JWT — use uma string longa e aleatória em produção
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3333
NODE_ENV="development"

# CORS — em produção, colocar o domínio real do frontend (separar por vírgula se mais de um)
# Exemplo: CORS_ORIGIN="https://harmonyhub.pages.dev,https://www.harmonyhub.com.br"
CORS_ORIGIN="http://localhost:8080,http://localhost:5173"
